  m_text: "\u6E38\u620F\u89C4\u5219\uFF1A\n1.\u952E\u76D8WASD\u79FB\u52A8\uFF0C\u70B9\u51FB\u9F20\u6807\u5DE6\u952E\u8FDB\u884C\u666E\u901A\u653B\u51FB\uFF08\u957F\u6309\u53EF\u8FDE\u7EED\u653B\u51FB\uFF09\uFF0C\u70B9\u51FB\u9F20\u6807\u53F3\u952E\u91CA\u653E\u6280\u80FD\uFF1B\n2.\u666E\u901A\u653B\u51FB\u6BCF\u547D\u4E2D\u4E00\u6B21\uFF0C\u589E\u52A01\u70B9NP\uFF0CNP\u6EE1\u65F6\u53EF\u91CA\u653E\u4E00\u6B21\u6280\u80FD\uFF1B\n3.\u6280\u80FD\uFF1A\u6309\u4E0B\u9F20\u6807\u53F3\u952E\u67E5\u770B\u8303\u56F4\uFF0C\u518D\u6B21\u677E\u5F00\u91CA\u653E\u6280\u80FD\u3002\u6280\u80FD\u670915\u79D2\u6301\u7EED\u65F6\u95F4\uFF1B\n4.\u901A\u8FC7\u51FB\u6740\u654C\u4EBA\u83B7\u5F97\u5206\u6570\uFF0C\u6BCF\u7D2F\u8BA1\u4E00\u5B9A\u5206\u6570\u53EF\u83B7\u5F97\u4E00\u9879\u589E\u76CA\uFF0C\u540C\u65F6\u654C\u4EBA\u7684\u5C5E\u6027\u4E5F\u4F1A\u6709\u4E9B\u8BB8\u63D0\u5347\uFF1B\n5.\u73A9\u5BB6HP\u4E0A\u9650\u4E3A10\uFF0C\u6BCF\u4E0E\u654C\u4EBA\u78B0\u649E\u4E00\u6B21\u5219HP-1\uFF1B\n6.\u76EE\u6807\u662F\u5B58\u6D3B\u5C3D\u53EF\u80FD\u4E45\u7684\u65F6\u95F4\u3002\u51B2\u51B2\u51B2\uFF01"
